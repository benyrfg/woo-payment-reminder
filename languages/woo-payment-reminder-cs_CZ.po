msgid "Payment Reminder"
msgstr "Připomenutí platby"

msgid "Sends a reminder email for unpaid orders after a configurable number of days."
msgstr "Odesílá e-mail s připomenutím platby po konfigurovatelném počtu dní."

msgid "Reminder: Complete your payment for order #{order_id}"
msgstr "Připomenutí: Dokončete platbu za objednávku #{order_id}"

msgid "Enable/Disable"
msgstr "Povolit/Zakázat"

msgid "Enable this email"
msgstr "Povolit tento e-mail"

msgid "Hours before first reminder"
msgstr "Hodiny před prvním připomenutím"

msgid "Second reminder"
msgstr "Druhé připomenutí"

msgid "Enable second reminder email"
msgstr "Povolit e-mail s druhým připomenutím"

msgid "Hours before second reminder"
msgstr "Hodiny před druhým připomenutím"

msgid "Hello %s,"
msgstr "Dobrý den,"

msgid "We noticed that your order <strong>#%s</strong> is still awaiting payment."
msgstr "zjistili jsme, že vaše objednávka č. <strong>%s</strong> stále čeká na zaplacení."

msgid "We noticed that your order #%s is still awaiting payment."
msgstr "Zjistili jsme, že vaše objednávka #%s stále čeká na platbu."

msgid "To complete your purchase, please proceed with the payment at your earliest convenience."
msgstr "Pro dokončení objednávky prosím proveďte platbu co nejdříve."

msgid "Pay Now"
msgstr "Zaplatit nyní"

msgid "Payment link:"
msgstr "Odkaz k platbě:"

msgid "If you have already completed the payment, please contact us."
msgstr "Pokud jste již platbu provedli, kontaktujte nás."

msgid "Thank you for shopping with us."
msgstr "Děkujeme za váš nákup."

msgid "Payment reminder email sent to customer."
msgstr "Zákazníkovi byl odeslán e-mail s připomenutím platby."

msgid "Second payment reminder email sent to customer."
msgstr "Zákazníkovi byl odeslán e-mail s druhým připomenutím platby."
